<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".authentication.SignUp">

    <!-- TODO: Update blank fragment layout -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginEnd="2dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <EditText
                android:id="@+id/name"
                android:layout_width="300dp"
                android:layout_height="55dp"

                android:layout_marginBottom="20dp"
                android:background="@drawable/customedittext"
                android:drawableStart="@drawable/usernamepng"
                android:drawablePadding="10dp"
                android:elevation="3dp"
                android:ems="10"
                android:hint="Name"
                android:inputType="textPersonName"
                android:maxEms="10"
                android:paddingStart="10dp"
                android:textColor="#4169e1"
                android:textColorHint="#4169e1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/customedittext"
                    android:drawableStart="@drawable/usernamepng"
                    android:drawablePadding="10dp"
                    android:elevation="3dp"
                    android:ems="10"
                    android:hint="Phone Number"
                    android:inputType="textPersonName"
                    android:maxEms="10"
                    android:paddingStart="10dp"
                    android:textColor="#4169e1"
                    android:textColorHint="#4169e1"
                    android:visibility="visible" />

                <EditText
                    android:id="@+id/phone_otp"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:layout_marginEnd="20dp"
                    android:visibility="gone"
                    android:background="@drawable/customedittext"
                    android:drawableStart="@drawable/usernamepng"
                    android:drawablePadding="10dp"
                    android:elevation="3dp"
                    android:ems="10"
                    android:hint="Enter Otp"
                    android:inputType="textPersonName"
                    android:maxEms="10"
                    android:paddingStart="10dp"
                    android:textColor="#4169e1"
                    android:textColorHint="#4169e1" />

                <Button
                    android:id="@+id/verify_num"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/custombutton"
                    android:backgroundTint="@color/teal_700"
                    android:text="Send Otp"
                    android:textAllCaps="false"
                    android:textColor="#FFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/email"
                    android:layout_width="300dp"
                    android:layout_height="55dp"
                    android:background="@drawable/customedittext"
                    android:drawableStart="@drawable/usernamepng"
                    android:drawablePadding="10dp"
                    android:elevation="3dp"
                    android:ems="10"
                    android:hint="Email"
                    android:inputType="textPersonName"
                    android:maxEms="10"
                    android:paddingStart="10dp"
                    android:textColor="#4169e1"
                    android:textColorHint="#4169e1"
                    app:layout_constraintBottom_toTopOf="@+id/password"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/phonenumber" />

                <Button
                    android:id="@+id/verify_email"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:visibility="gone"
                    android:background="@drawable/custombutton"
                    android:backgroundTint="@color/teal_700"
                    android:text="Verify Email"
                    android:textAllCaps="false"
                    android:textColor="#FFF" />
            </LinearLayout>

            <EditText
                android:id="@+id/password"
                android:layout_width="300dp"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/customedittext"
                android:drawableStart="@drawable/passwordpng"
                android:drawablePadding="10dp"
                android:elevation="3dp"
                android:ems="10"
                android:hint="Password"
                android:inputType="textPassword"
                android:maxEms="10"
                android:paddingStart="10dp"
                android:textColor="#4169e1"
                android:textColorHint="#4169e1" />

            <EditText
                android:id="@+id/retypepassword"
                android:layout_width="300dp"
                android:layout_height="55dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/customedittext"
                android:drawableStart="@drawable/passwordpng"
                android:drawablePadding="10dp"
                android:elevation="3dp"
                android:ems="10"
                android:hint="Re-type Password"
                android:inputType="textPassword"
                android:maxEms="10"
                android:paddingStart="10dp"
                android:textColor="#4169e1"
                android:textColorHint="#4169e1" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/isFarmer"
                android:layout_width="190dp"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/custombutton"
                android:paddingStart="15dp"
                android:text="Farmer Account"
                android:textColor="#FFF" />

            <Button
                android:id="@+id/signUp"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/custombutton"
                android:text="Signup"
                android:textAllCaps="false"
                android:textColor="#FFF" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>